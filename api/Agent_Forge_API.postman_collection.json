          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "    url: pm.collectionVariables.get('base_url') + '/api/tasks',",
                  "    method: 'POST',",
                  "    header: { 'Content-Type': 'application/json' },",
                  "    body: { mode: 'raw', raw: JSON.stringify({ name: 'Temp task for deletion' }) }",
                  "}, function(err, res) {",
                  "    pm.collectionVariables.set('delete_task_id', res.json().id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', function() {",
                  "    pm.response.to.have.status(204);",
