                  "pm.collectionVariables.set('task_id', json.id);",
                  "pm.test('Task has id', function() {",
                  "    pm.expect(json.id).to.be.a('string');",
                  "});",
                  "pm.test('Task type is task', function() {",
                  "    pm.expect(json.type).to.eql('task');",
                  "});"
